# ── Confluent Cloud ──────────────────────────────────────────────────────────
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your_api_key_here
CONFLUENT_API_SECRET=your_api_secret_here

# ── Confluent Schema Registry ─────────────────────────────────────────────────
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-2.aws.confluent.cloud
SCHEMA_REGISTRY_API_KEY=your_sr_api_key_here
SCHEMA_REGISTRY_API_SECRET=your_sr_api_secret_here

# ── Kafka Topics ──────────────────────────────────────────────────────────────
VITALS_TOPIC=icu-vitals
ALERTS_TOPIC=sepsis-alerts

# ── App Settings ──────────────────────────────────────────────────────────────
# Set to "true" to run without Confluent (local demo mode)
MOCK_MODE=true
PRODUCER_INTERVAL_SECONDS=4
NUM_PATIENTS=8
